        \
        \cf20 // answer\cf18 \
        \cf19 int\cf18  best = f[n - 1][0];\
        
\f9\b \cf16 for
\f6\b0 \cf18  (\cf19 int\cf18  i = 1; i < n; i++) \{\
            best = Math.min(best, f[n - 1][i]);\
        \}\
        
\f9\b \cf16 return
\f6\b0 \cf18  best;\
    \}\
\}\
