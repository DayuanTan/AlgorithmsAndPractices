\f9\b \cf16 if
\f6\b0 \cf18  (\cf19 triangle\cf18 .\cf19 size\cf18 () == 0)\
            
\f9\b \cf16 return
\f6\b0 \cf18  0;\
            \
        vector<\cf19 int\cf18 > f(\cf19 triangle\cf18 [\cf19 triangle\cf18 .\cf19 size\cf18 ()-1].\cf19 size\cf18 ());\
        \
        f[0] = \cf19 triangle\cf18 [0][0];\
        
\f9\b \cf16 for
\f6\b0 \cf18 (\cf19 int\cf18  i = 1; i < \cf19 triangle\cf18 .\cf19 size\cf18 (); i++)\
            
\f9\b \cf16 for
\f6\b0 \cf18 (\cf19 int\cf18  j = \cf19 triangle\cf18 [i].\cf19 size\cf18 () - 1; j >= 0; j--)\
                
\f9\b \cf16 if
\f6\b0 \cf18  (j == 0)\
