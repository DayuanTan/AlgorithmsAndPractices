     */\cf18 \
    
\f9\b \cf16 public
\f6\b0 \cf18  \cf19 int\cf18  minimumTotal(\cf19 int\cf18 [][] triangle) \{\
        
\f9\b \cf16 if
\f6\b0 \cf18  (triangle == 
\f9\b \cf16 null
\f6\b0 \cf18  || triangle.length == 0) \{\
            
\f9\b \cf16 return
\f6\b0 \cf18  -1;\
        \}\
        
\f9\b \cf16 if
\f6\b0 \cf18  (triangle[0] == 
\f9\b \cf16 null
\f6\b0 \cf18  || triangle[0].length == 0) \{\
            
\f9\b \cf16 return
\f6\b0 \cf18  -1;\
        \}\
        \
        \cf20 // state: f[x][y] = minimum path value from 0,0 to x,y\cf18 \
        \cf19 int\cf18  n = triangle.length;\
        \cf19 int\cf18 [][] f = new \cf19 int\cf18 [n][n];\
        \
        \cf20 // initialize \cf18 \
        f[0][0] = triangle[0][0];\
        
\f9\b \cf16 for
\f6\b0 \cf18  (\cf19 int\cf18  i = 1; i < n; i++) \{\
            f[i][0] = f[i - 1][0] + triangle[i][0];\
            f[i][i] = f[i - 1][i - 1] + triangle[i][i];\
        \}\
        \
        \cf20 // top down\cf18 \
        
\f9\b \cf16 for
\f6\b0 \cf18  (\cf19 int\cf18  i = 1; i < n; i++) \{\
            
\f9\b \cf16 for
\f6\b0 \cf18  (\cf19 int\cf18  j = 1; j < i; j++) \{\
                f[i][j] = Math.min(f[i - 1][j], f[i - 1][j - 1]) + triangle[i][j];\
            \}\
